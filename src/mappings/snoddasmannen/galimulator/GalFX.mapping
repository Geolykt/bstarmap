	FIELD RENDERCACHE_LOCAL RENDERCACHE_LOCAL Ljava/lang/ThreadLocal;
	FIELD s friendlyFont Lcom/badlogic/gdx/graphics/g2d/BitmapFont;
		COMMENT When the current locale is set as russian, this BitmapFont corresponds to the
		COMMENT {@value "data/fonts/Raleway/SemiBold-new-24.fnt"} file. Otherwise, it will correspond
		COMMENT to the {@value "data/fonts/Signika.fnt"} font file.
		COMMENT
		COMMENT This font has, irrespective of above choice, libGDX markup enabled.
