	FIELD a mainSpriteBatch Lcom/badlogic/gdx/graphics/g2d/SpriteBatch;
	FIELD A bigTextByDefault Z
		COMMENT Whether to prefer using the large monotype font over the small monotype font
		COMMENT when using MONOTYPE_DEFAULT.
